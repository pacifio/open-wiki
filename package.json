{
  "name": "open-wiki",
  "version": "0.0.2",
  "description": "Open-source code wiki generator powered by tree-sitter and LLMs",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "ow": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
