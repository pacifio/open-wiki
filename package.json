    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^4.3.0",
    "better-sqlite3": "^9.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "glob": "^11.0.0",
    "ora": "^8.1.0",
    "p-limit": "^7.3.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2",
    "zod": "^3.25.76"
